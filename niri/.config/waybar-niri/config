{
  "layer": "top",
  "position": "top",
  "height": 34,
  "modules-left": ["niri/workspaces"],
  "modules-center": ["niri/window"],
  "modules-right": ["custom/cpugraph", "memory", "temperature", "battery", "custom/niri-monitor", "custom/niri-caffeinate", "custom/niri-security", "bluetooth", "niri/language", "network", "pulseaudio", "clock"],
  "niri/workspaces": {
    "all-outputs": true,
    "format": "{value}"
  },
  "niri/window": {
    "format": "{app_id}: {title}",
    "icon": false,
    "separate-outputs": true
  },
  "memory": {
    "interval": 3,
    "format": "َ°چ› {used:0.0f}G",
    "tooltip": true
  },
  "network": {
    "format-wifi": "َ°–©",
    "format-ethernet": "َ°ˆ€ {ifname}",
    "format-disconnected": "َ°–ھ offline",
    "tooltip-format": "{ifname} {ipaddr} ïچک {bandwidthDownBits} ïچ› {bandwidthUpBits}",
    "interval": 3,
    "on-click": "nm-connection-editor"
  },
  "niri/language": {
    "format": "َ°ŒŒ {short}"
  },
  "bluetooth": {
    "format": "َ°‚¯",
    "controller": "hci0",
    "format-disabled": "",
    "format-off": "َ°‚¯",
    "format-on": "َ°‚¯",
    "format-connected": "َ°‚± {num_connections} connected",
    "tooltip-format": "{controller_alias}\t{controller_address}",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "on-click": "~/.local/bin/rofi-bluetooth"
  },
  "custom/cpugraph": {
    "interval": 1,
    "exec": "$HOME/.local/bin/waybar-cpu-graph",
    "format": "{}",
    "tooltip": false
  },
  "custom/niri-security": {
    "exec": "$HOME/.local/bin/niri-power-mode waybar-mode",
    "return-type": "json",
    "format": "{text}",
    "signal": 11,
    "on-click": "$HOME/.local/bin/niri-power-mode toggle-mode",
    "tooltip": true
  },
  "custom/niri-monitor": {
    "exec": "$HOME/.local/bin/niri-power-mode waybar-monitor",
    "return-type": "json",
    "format": "{text}",
    "interval": 5,
    "signal": 13,
    "hide-empty-text": true,
    "tooltip": true
  },
  "custom/niri-caffeinate": {
    "exec": "$HOME/.local/bin/niri-power-mode waybar-caffeinate",
    "return-type": "json",
    "format": "{text}",
    "signal": 12,
    "hide-empty-text": true,
    "on-click": "$HOME/.local/bin/niri-power-mode toggle-caffeinate",
    "tooltip": true
  },
  "temperature": {
    "hwmon-path": "/sys/class/thermal/thermal_zone0/temp",
    "critical-threshold": 80,
    "format": "َ°”ڈ {temperatureC}آ°"
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "َ°‌ں mute",
    "tooltip": true,
    "scroll-step": 5,
    "on-click": "pavucontrol",
    "format-icons": {
      "default": ["َ°•؟", "َ°–€", "َ°•¾"]
    }
  },
  "battery": {
    "format": "{icon} {capacity}%",
    "format-charging": "َ°‚„ {capacity}%",
    "format-alt": "{time}",
    "states": {
      "warning": 25,
      "critical": 10
    },
    "format-icons": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾"]
  },
  "clock": {
    "format": "َ°¥” {:%a %d %b  %H:%M}",
    "tooltip-format": "{:%A, %d %B %Y}"
  }
}
