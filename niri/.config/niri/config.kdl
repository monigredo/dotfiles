// Minimal additive Niri config for this repo.
// Keep this focused on Stage 1 session completeness rather than perfect parity.

input {
    mod-key "Super"
    mod-key-nested "Alt"

    keyboard {
        xkb {
            layout "us,ua"
            options "ctrl:nocaps"
        }

        numlock
    }

    touchpad {
        tap
        drag true
        dwt
        natural-scroll
        scroll-method "two-finger"
        accel-profile "adaptive"
        accel-speed 0.08
    }

    mouse {
        natural-scroll
        accel-profile "adaptive"
        accel-speed 0.02
    }

    focus-follows-mouse max-scroll-amount="0%"
}

layout {
    gaps 8
    center-focused-column "never"

    default-column-width {
        proportion 0.5
    }

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
        proportion 1.0
    }

    preset-window-heights {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
        proportion 1.0
    }

    focus-ring {
        width 2
        active-color "#88c0d0"
        inactive-color "#4c566a"
    }

    border {
        off
    }
}

prefer-no-csd

screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

spawn-at-startup "mako"
spawn-at-startup "/usr/libexec/lxqt-policykit-agent"
spawn-sh-at-startup "~/.local/bin/theme-toggle dark"
spawn-sh-at-startup "pkill waybar 2>/dev/null; exec waybar -c \"$HOME/.config/waybar-niri/config\" -s \"$HOME/.config/waybar-niri/style.css\""
spawn-sh-at-startup "~/.local/bin/niri-power-mode apply-idle"

switch-events {
    lid-close { spawn "bash" "-lc" "~/.local/bin/niri-handle-lid.sh"; }
}

binds {
    Super+Return { spawn "ghostty"; }
    Super+Shift+Return { spawn-sh "~/.local/bin/dev-terminal"; }
    Super+Space { spawn "rofi" "-show" "drun"; }
    Super+O { spawn-sh "~/.local/bin/obsidian-launch"; }
    Super+Shift+T { spawn-sh "~/.local/bin/theme-toggle toggle"; }
    Super+Shift+X { spawn-sh "~/.local/bin/niri-power-mode toggle-caffeinate"; }
    Super+Q repeat=false { close-window; }

    Ctrl+Space { switch-layout "next"; }

    Super+Left { focus-column-left; }
    Super+Down { focus-window-down; }
    Super+Up { focus-window-up; }
    Super+Right { focus-column-right; }
    Super+Ctrl+Left { move-column-left; }
    Super+Ctrl+Right { move-column-right; }
    Super+R { switch-preset-column-width; }
    Super+Shift+R { switch-preset-window-height; }
    Super+F { fullscreen-window; }
    Super+Shift+F { maximize-column; }

    Super+Shift+Left { focus-monitor-left; }
    Super+Shift+Right { focus-monitor-right; }
    Super+Alt+Shift+Left { move-window-to-monitor-left; }
    Super+Alt+Shift+Right { move-window-to-monitor-right; }
    Super+Ctrl+Shift+Left { move-workspace-to-monitor-left; }
    Super+Ctrl+Shift+Right { move-workspace-to-monitor-right; }

    Super+1 { focus-workspace 1; }
    Super+2 { focus-workspace 2; }
    Super+3 { focus-workspace 3; }
    Super+4 { focus-workspace 4; }
    Super+5 { focus-workspace 5; }
    Super+6 { focus-workspace 6; }
    Super+7 { focus-workspace 7; }
    Super+8 { focus-workspace 8; }
    Super+9 { focus-workspace 9; }

    Super+Ctrl+1 { move-column-to-workspace 1; }
    Super+Ctrl+2 { move-column-to-workspace 2; }
    Super+Ctrl+3 { move-column-to-workspace 3; }
    Super+Ctrl+4 { move-column-to-workspace 4; }
    Super+Ctrl+5 { move-column-to-workspace 5; }
    Super+Ctrl+6 { move-column-to-workspace 6; }
    Super+Ctrl+7 { move-column-to-workspace 7; }
    Super+Ctrl+8 { move-column-to-workspace 8; }
    Super+Ctrl+9 { move-column-to-workspace 9; }

    Ctrl+Left { focus-workspace-down; }
    Ctrl+Right { focus-workspace-up; }

    Super+WheelScrollLeft { focus-column-left; }
    Super+WheelScrollRight { focus-column-right; }
    Super+Ctrl+WheelScrollLeft { move-column-left; }
    Super+Ctrl+WheelScrollRight { move-column-right; }
    Super+WheelScrollUp cooldown-ms=150 { focus-workspace-up; }
    Super+WheelScrollDown cooldown-ms=150 { focus-workspace-down; }
    Super+Ctrl+WheelScrollUp cooldown-ms=150 { move-column-to-workspace-up; }
    Super+Ctrl+WheelScrollDown cooldown-ms=150 { move-column-to-workspace-down; }
    Super+TouchpadScrollLeft cooldown-ms=150 { focus-column-right; }
    Super+TouchpadScrollRight cooldown-ms=150 { focus-column-left; }
    Super+Ctrl+TouchpadScrollLeft cooldown-ms=150 { move-column-right; }
    Super+Ctrl+TouchpadScrollRight cooldown-ms=150 { move-column-left; }
    Super+TouchpadScrollUp cooldown-ms=150 { focus-workspace-up; }
    Super+TouchpadScrollDown cooldown-ms=150 { focus-workspace-down; }
    Super+Ctrl+TouchpadScrollUp cooldown-ms=150 { move-column-to-workspace-up; }
    Super+Ctrl+TouchpadScrollDown cooldown-ms=150 { move-column-to-workspace-down; }

    Super+F1 allow-when-locked=true { spawn "brightnessctl" "set" "5%-"; }
    Super+F2 allow-when-locked=true { spawn "brightnessctl" "set" "+5%"; }

    Super+F11 allow-when-locked=true { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"; }
    Super+F12 allow-when-locked=true { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+"; }
    Super+Shift+F12 allow-when-locked=true { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"; }

    Super+F8 allow-when-locked=true { spawn-sh "playerctl play-pause"; }
    Super+F9 allow-when-locked=true { spawn-sh "playerctl previous"; }
    Super+F10 allow-when-locked=true { spawn-sh "playerctl next"; }

    Super+Shift+4 { spawn-sh "grim -g \"$(slurp)\" - | wl-copy"; }
    Super+Shift+B { spawn-sh "~/.local/bin/rofi-bluetooth"; }
    Super+Shift+N { spawn-sh "~/.local/bin/wifi-menu"; }
    Super+Ctrl+N { spawn "nm-connection-editor"; }
    Ctrl+Super+Q { spawn "swaylock" "-f" "-c" "000000" "-k"; }

    Super+Shift+C { spawn "niri" "msg" "action" "load-config-file"; }
    Super+Shift+E { quit; }
}
