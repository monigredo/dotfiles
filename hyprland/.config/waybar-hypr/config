{
  "layer": "top",
  "position": "top",
  "height": 34,
  "modules-left": ["hyprland/workspaces"],
  "modules-center": [],
  "modules-right": ["custom/mullvad", "custom/protonvpn", "custom/cpugraph", "memory", "temperature", "battery", "bluetooth", "custom/kblayout", "network", "pulseaudio", "clock"],
  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{name}"
  },
  "memory": {
    "interval": 3,
    "format": "َ°چ› {used:0.0f}G",
    "tooltip": true
  },
  "network": {
    "format-wifi": "َ°–©",
    "format-ethernet": "َ°ˆ€ {ifname}",
    "format-disconnected": "َ°–ھ offline",
    "tooltip-format": "{ifname} {ipaddr} ïچک {bandwidthDownBits} ïچ› {bandwidthUpBits}",
    "interval": 3,
    "on-click": "nm-connection-editor"
  },
  "custom/kblayout": {
    "exec": "~/.local/bin/hypr-kblayout-waybar",
    "interval": 1,
    "format": "َ°ŒŒ {}",
    "tooltip": false
  },
  "custom/mullvad": {
    "return-type": "json",
    "exec": "~/.local/bin/mullvad-waybar",
    "interval": 5,
    "signal": 8,
    "format": "  {text} ",
    "on-click": "~/.local/bin/mullvad-waybar toggle && pkill -RTMIN+8 waybar"
  },
  "custom/protonvpn": {
    "return-type": "json",
    "exec": "~/.local/bin/protonvpn-waybar",
    "interval": 5,
    "signal": 9,
    "format": "  {text} ",
    "on-click": "~/.local/bin/protonvpn-waybar toggle && pkill -RTMIN+9 waybar"
  },
  "bluetooth": {
    "format": "َ°‚¯",
    "controller": "hci0",
    "format-disabled": "",
    "format-off": "َ°‚¯",
    "format-on": "َ°‚¯",
    "format-connected": "َ°‚± {num_connections} connected",
    "tooltip-format": "{controller_alias}\t{controller_address}",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "on-click": "~/.local/bin/rofi-bluetooth"
  },
  "custom/cpugraph": {
    "interval": 1,
    "exec": "$HOME/.local/bin/waybar-cpu-graph",
    "format": "{}",
    "tooltip": false
  },
  "temperature": {
    "hwmon-path": "/sys/class/thermal/thermal_zone0/temp",
    "critical-threshold": 80,
    "format": "َ°”ڈ {temperatureC}آ°"
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "َ°‌ں mute",
    "tooltip": true,
    "scroll-step": 5,
    "on-click": "pavucontrol",
    "format-icons": {
      "default": ["َ°•؟", "َ°–€", "َ°•¾"]
    }
  },
  "battery": {
    "format": "{icon} {capacity}%",
    "format-charging": "َ°‚„ {capacity}%",
    "format-alt": "{time}",
    "states": {
      "warning": 25,
      "critical": 10
    },
    "format-icons": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾"]
  },
  "clock": {
    "format": "َ°¥” {:%a %d %b  %H:%M}",
    "tooltip-format": "{:%A, %d %B %Y}"
  }
}
