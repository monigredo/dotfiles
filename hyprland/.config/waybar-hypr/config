{
  "layer": "top",
  "position": "top",
  "height": 28,
  "modules-left": ["hyprland/workspaces"],
  "modules-center": [],
  "modules-right": ["custom/cpugraph", "memory", "network", "custom/kblayout", "custom/mullvad", "custom/protonvpn", "bluetooth", "pulseaudio", "temperature", "battery", "clock"],
  "memory": {
    "interval": 3,
    "format": "´âë {used:0.1f}G  ",
    "tooltip": true
  },
  "network": {
    "format-wifi": "´ç½  {essid} {signalStrength}%",
    "format-ethernet": "´ø┐ {ifname}",
    "format-disconnected": "´ü▒ offline",
    "tooltip-format": "{ifname} {ipaddr} ´ıİ {bandwidthDownBits} ´ıø {bandwidthUpBits}",
    "interval": 3,
    "on-click": "nm-connection-editor"
  },
  "custom/kblayout": {
    "exec": "~/.local/bin/hypr-kblayout-waybar",
    "interval": 1,
    "format": "´ä£ {}",
    "tooltip": false
  },
  "custom/mullvad": {
    "return-type": "json",
    "exec": "~/.local/bin/mullvad-waybar",
    "interval": 5,
    "signal": 8,
    "format": "  {text} ",
    "on-click": "~/.local/bin/mullvad-waybar toggle && pkill -RTMIN+8 waybar"
  },
  "custom/protonvpn": {
    "return-type": "json",
    "exec": "~/.local/bin/protonvpn-waybar",
    "interval": 5,
    "signal": 9,
    "format": "  {text} ",
    "on-click": "~/.local/bin/protonvpn-waybar toggle && pkill -RTMIN+9 waybar"
  },
  "bluetooth": {
    "format": "´èö {status}",
    "controller": "hci0",
    "format-disabled": "",
    "format-connected": "´èö {num_connections} connected",
    "tooltip-format": "{controller_alias}\t{controller_address}",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "on-click": "~/.local/bin/rofi-bluetooth"
  },
  "custom/cpugraph": {
    "interval": 1,
    "exec": "$HOME/.local/bin/waybar-cpu-graph",
    "format": "{}",
    "tooltip": false
  },
  "temperature": {
    "hwmon-path": "/sys/class/thermal/thermal_zone0/temp",
    "critical-threshold": 80,
    "format": "­şîí {temperatureC}┬░C"
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "´Ü® mute",
    "tooltip": true,
    "scroll-step": 5,
    "on-click": "pavucontrol",
    "format-icons": {
      "default": ["´ÇĞ", "´Çğ", "´Ç¿"]
    }
  },
  "battery": {
    "format": "{icon} {capacity}%",
    "format-charging": "´çĞ {capacity}%",
    "format-alt": "{time}",
    "states": {
      "warning": 25,
      "critical": 10
    },
    "icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
  },
  "clock": {
    "format": "´Çù {:%Y-%m-%d %H:%M}",
    "tooltip-format": "{:%A, %d %B %Y}"
  }
}
