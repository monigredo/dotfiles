{
  "layer": "top",
  "position": "top",
  "height": 28,
  "modules-left": ["sway/workspaces"],
  "modules-center": [],
  "modules-right": ["cpu", "memory", "network", "custom/kblayout", "custom/mullvad", "custom/protonvpn", "bluetooth", "pulseaudio", "temperature", "battery", "clock"],

  "memory": {
    "interval": 3,
    "format": "ΎΔΚ {used:0.1f}G  ",
    "tooltip": true
  },

  "network": {
    "format-wifi": "ΎΘτ  {essid} {signalStrength}%",
    "format-ethernet": "Ύδ┐ {ifname}",
    "format-disconnected": "ΎΒ▒ offline",
    "tooltip-format": "{ifname} {ipaddr} ΎΞα {bandwidthDownBits} ΎΞδ {bandwidthUpBits}",
    "interval": 3,
    "on-click": "nm-connection-editor"
  },

  "custom/kblayout": {
    "exec": "/home/user/dotfiles/shell/.local/bin/sway-kblayout-waybar",
    "interval": 1,
    "format": "ΎΕε {}",
    "tooltip": false
  },

  "custom/mullvad": {
    "return-type": "json",
    "exec": "~/.local/bin/mullvad-waybar",
    "interval": 5,
    "signal": 8,
    "format": "  {text} ",
    "on-click": "~/.local/bin/mullvad-waybar toggle && pkill -RTMIN+8 waybar"
  },

  "custom/protonvpn": {
    "return-type": "json",
    "exec": "~/.local/bin/protonvpn-waybar",
    "interval": 5,
    "signal": 9,
    "format": "  {text} ",
    "on-click": "~/.local/bin/protonvpn-waybar toggle && pkill -RTMIN+9 waybar"
  },

  "bluetooth": {
    "format": "ΎΛΦ {status}",
    "controller": "hci0",
    "format-disabled": "",
    "format-connected": "ΎΛΦ {num_connections} connected",
    "tooltip-format": "{controller_alias}\t{controller_address}",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "on-click": "~/.local/bin/rofi-bluetooth"
  },


  "cpu": {
    "format": "ΎΜδ {usage:>2}%",
    "tooltip": true
  },

  "temperature": {
    "hwmon-path": "/sys/class/thermal/thermal_zone0/temp",
    "critical-threshold": 80,
    "format": "ΏθΝκ {temperatureC}┬░C"
  },

  "pulseaudio": {
  "format": "{icon} {volume}%",
  "format-muted": "Ύγσ mute",
  "tooltip": true,
  "scroll-step": 5,
  "on-click": "pavucontrol",
  "format-icons": {
    "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    }
  },


  "battery": {
    "format": "{icon} {capacity}%",
    "format-charging": "ΎΘο {capacity}%",
    "format-alt": "{time}",
    "states": {
      "warning": 25,
      "critical": 10
    },
    "icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
  },

  "clock": {
    "format": "ΎΑΩ {:%Y-%m-%d %H:%M}",
    "tooltip-format": "{:%A, %d %B %Y}"
  }

}
