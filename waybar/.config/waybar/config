{
  "layer": "top",
  "position": "top",
  "height": 28,
  "modules-left": ["sway/workspaces"],
  "modules-center": [],
  "modules-right": ["custom/cpugraph", "memory", "network", "custom/kblayout", "custom/mullvad", "custom/protonvpn", "bluetooth", "pulseaudio", "temperature", "battery", "clock"],

  "memory": {
    "interval": 3,
    "format": " {used:0.1f}G  ",
    "tooltip": true
  },

  "network": {
    "format-wifi": "  {essid} {signalStrength}%",
    "format-ethernet": " {ifname}",
    "format-disconnected": " offline",
    "tooltip-format": "{ifname} {ipaddr}  {bandwidthDownBits}  {bandwidthUpBits}",
    "interval": 3,
    "on-click": "nm-connection-editor"
  },

  "custom/kblayout": {
    "exec": "~/.local/bin/sway-kblayout-waybar",
    "interval": 1,
    "format": " {}",
    "tooltip": false
  },

  "custom/mullvad": {
    "return-type": "json",
    "exec": "~/.local/bin/mullvad-waybar",
    "interval": 5,
    "signal": 8,
    "format": "  {text} ",
    "on-click": "~/.local/bin/mullvad-waybar toggle && pkill -RTMIN+8 waybar"
  },

  "custom/protonvpn": {
    "return-type": "json",
    "exec": "~/.local/bin/protonvpn-waybar",
    "interval": 5,
    "signal": 9,
    "format": "  {text} ",
    "on-click": "~/.local/bin/protonvpn-waybar toggle && pkill -RTMIN+9 waybar"
  },

  "bluetooth": {
    "format": " {status}",
    "controller": "hci0",
    "format-disabled": "",
    "format-connected": " {num_connections} connected",
    "tooltip-format": "{controller_alias}\t{controller_address}",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "on-click": "~/.local/bin/rofi-bluetooth"
  },

  "custom/cpugraph": {
    "interval": 1,
    "exec": "$HOME/.local/bin/waybar-cpu-graph",
    "format": "{}",
    "tooltip": false
  },

  "temperature": {
    "hwmon-path": "/sys/class/thermal/thermal_zone0/temp",
    "critical-threshold": 80,
    "format": "🌡 {temperatureC}°C"
  },

  "pulseaudio": {
  "format": "{icon} {volume}%",
  "format-muted": " mute",
  "tooltip": true,
  "scroll-step": 5,
  "on-click": "pavucontrol",
  "format-icons": {
    "default": ["", "", ""]
    }
  },


  "battery": {
    "format": "{icon} {capacity}%",
    "format-charging": " {capacity}%",
    "format-alt": "{time}",
    "states": {
      "warning": 25,
      "critical": 10
    },
    "icons": ["", "", "", "", ""]
  },

  "clock": {
    "format": " {:%Y-%m-%d %H:%M}",
    "tooltip-format": "{:%A, %d %B %Y}"
  }

}
