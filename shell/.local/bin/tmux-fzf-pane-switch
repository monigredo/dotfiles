#!/usr/bin/env bash
set -euo pipefail

if ! command -v fzf >/dev/null 2>&1 || ! command -v fzf-tmux >/dev/null 2>&1; then
  tmux display-message "fzf not installed (need fzf + fzf-tmux)"
  exit 0
fi

choice="$(tmux list-panes -F '#{pane_index}: #{pane_title}' | fzf-tmux -p 80%,60%)" || exit 0
index="$(printf '%s\n' "$choice" | awk -F: '{print $1}')"
[ -n "${index:-}" ] || exit 0

tmux select-pane -t "$index"
