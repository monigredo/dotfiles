#!/usr/bin/env bash
set -euo pipefail

if ! command -v mullvad >/dev/null 2>&1; then
  exit 0
fi

max_attempts=30
sleep_seconds=2

for _ in $(seq 1 "$max_attempts"); do
  auto_connect=$(mullvad auto-connect get 2>/dev/null || true)
  if [[ $auto_connect == *off* ]]; then
    mullvad auto-connect set on >/dev/null 2>&1 || true
  fi

  status=$(mullvad status 2>/dev/null || true)
  status_line=$(printf '%s\n' "$status" | head -n 1)

  shopt -s nocasematch
  if [[ $status == *"not logged in"* ]]; then
    shopt -u nocasematch
    exit 0
  fi
  if [[ $status_line == *connected* ]] || [[ $status_line == *connecting* ]] || [[ $status_line == *reconnecting* ]]; then
    shopt -u nocasematch
    exit 0
  fi
  shopt -u nocasematch

  mullvad connect >/dev/null 2>&1 || true
  sleep "$sleep_seconds"
done
